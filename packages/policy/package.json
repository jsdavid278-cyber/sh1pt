{
  "name": "@profullstack/sh1pt-policy",
  "version": "0.2.0",
  "description": "Store-policy linter for sh1pt — catches rejections before submission.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/profullstack/sh1pt.git",
    "directory": "packages/policy"
  },
  "homepage": "https://sh1pt.com",
  "bugs": "https://github.com/profullstack/sh1pt/issues",
  "keywords": [
    "sh1pt",
    "devtools",
    "publish",
    "lint"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@profullstack/sh1pt-core": "workspace:^"
  }
}
