{
  "name": "@profullstack/sh1pt-action-packs",
  "version": "0.0.1",
  "description": "Built-in sh1pt actions and workflow templates for the Actions Store.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/profullstack/sh1pt.git",
    "directory": "packages/actions"
  },
  "homepage": "https://sh1pt.com",
  "bugs": "https://github.com/profullstack/sh1pt/issues",
  "keywords": [
    "sh1pt",
    "github-actions",
    "workflow",
    "ci"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "*/README.md",
    "*/action.yml",
    "*/icon.png",
    "*/schema.json",
    "*/sh1pt.actionpack.yaml",
    "*/workflow.yml"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@profullstack/sh1pt-actions-fleet-core": "workspace:^"
  }
}
