{
  "name": "@profullstack/sh1pt-actions-fleet-core",
  "version": "0.0.1",
  "description": "Action-pack schema, validator, deterministic renderer, and catalog loader for sh1pt Actions Fleet.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/profullstack/sh1pt.git",
    "directory": "packages/actions-fleet-core"
  },
  "homepage": "https://sh1pt.com",
  "bugs": "https://github.com/profullstack/sh1pt/issues",
  "keywords": [
    "sh1pt",
    "github-actions",
    "workflow",
    "ci",
    "fleet"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@profullstack/sh1pt-core": "workspace:^",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  }
}
